---
// Данные о работах
const portfolioItems = [
  {
    id: 1,
    title: "Chrome Aurora Nails",
    service: "Gel Polish",
    description: "Iridescent chrome finish with aurora effect. Perfect for special occasions.",
    image: "/images/chromeauroranails.png",
    tags: ["Gel", "Chrome", "Trending 2026"],
    location: "Manhattan",
    duration: "60 min"
  },
  {
    id: 2,
    title: "3D Floral Sculpture",
    service: "Nail Art Design",
    description: "Hand-sculpted 3D flowers with pearl accents. Luxury bridal design.",
    image: "/images/3Dfloralsculpture.png",
    tags: ["3D Art", "Bridal", "Floral"],
    location: "Brooklyn",
    duration: "90 min"
  },
  {
    id: 3,
    title: "Velvet Matte Finish",
    service: "Dip Powder",
    description: "Soft velvet matte texture in deep burgundy. Fall/winter favorite.",
    image: "/images/velvetmattefinish.png",
    tags: ["Matte", "Dip Powder", "Seasonal"],
    location: "Queens",
    duration: "60 min"
  },
  {
    id: 4,
    title: "Glass Nails",
    service: "Nail Extensions",
    description: "Translucent glass effect with gold foil encapsulation.",
    image: "/images/glassnails.png",
    tags: ["Glass", "Extensions", "Luxury"],
    location: "Manhattan",
    duration: "120 min"
  },
  {
    id: 5,
    title: "French Ombre",
    service: "Classic Manicure",
    description: "Modern twist on French - pink ombre with white tips.",
    image: "/images/frenchombre.png",
    tags: ["French", "Ombre", "Classic"],
    location: "Staten Island",
    duration: "45 min"
  },
  {
    id: 6,
    title: "Cat Eye Gel",
    service: "Gel Polish",
    description: "Magnetic cat eye effect with deep blue shimmer.",
    image: "/images/cateyegel.png",
    tags: ["Cat Eye", "Magnetic", "Gel"],
    location: "Bronx",
    duration: "60 min"
  }
];
---

<section class="portfolio-section">
  <div class="portfolio-container">
    <!-- Заголовок секции -->
    <div class="portfolio-header">
      <h2 class="portfolio-title">
        <span class="title-small">OUR CREATIVE</span>
        <span class="title-large">PORTFOLIO<span class="dot">.</span></span>
      </h2>
      <p class="portfolio-subtitle">
        Explore our latest nail art creations and designs.<br>
        Each piece is uniquely crafted for our clients across New York.
      </p>
    </div>
    
    <!-- Фильтры -->
    <div class="portfolio-filters">
      <button class="filter-btn active" data-filter="all">All Work</button>
      <button class="filter-btn" data-filter="Gel Polish">💅 Gel Polish</button>
      <button class="filter-btn" data-filter="Nail Art Design">🎨 Nail Art</button>
      <button class="filter-btn" data-filter="Nail Extensions">✨ Extensions</button>
      <button class="filter-btn" data-filter="Classic Manicure">🤍 Classic</button>
    </div>
    
    <!-- Галерея -->
    <div class="portfolio-grid" id="portfolioGrid">
      {portfolioItems.map((item, index) => (
        <div 
          class="portfolio-item" 
          data-category={item.service}
          data-id={item.id}
          data-index={index}
          style={`--item-index: ${index}`}
        >
          <div class="portfolio-card">
            <div class="portfolio-image-wrapper">
              <img 
                src={item.image} 
                alt={`${item.title} - ${item.service} at our ${item.location} nail salon`}
                class="portfolio-image"
                loading="lazy"
              />
              <div class="portfolio-overlay">
                <div class="overlay-content">
                  <span class="service-badge">{item.service}</span>
                  <h3 class="overlay-title">{item.title}</h3>
                  <p class="overlay-description">{item.description}</p>
                  <div class="overlay-tags">
                    {item.tags.map(tag => (
                      <span class="overlay-tag">{tag}</span>
                    ))}
                  </div>
                  <div class="overlay-footer">
                    <span class="location-icon">📍 {item.location}</span>
                    <span class="duration-icon">⏱ {item.duration}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Ссылка на полное портфолио -->
    <div class="portfolio-footer">
      <a href="/portfolio" class="view-all-link">
        View full portfolio
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .portfolio-section {
    position: relative;
    width: 100%;
    padding: 120px 0;
    background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
    overflow: hidden;
  }
  
  .portfolio-section::before {
    content: '';
    position: absolute;
    top: -30%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255, 0, 0, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  
  .portfolio-section::after {
    content: '';
    position: absolute;
    bottom: -20%;
    right: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255, 0, 0, 0.08) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  
  .portfolio-container {
    max-width: 1520px;
    margin: 0 auto;
    padding: 0 26px;
    position: relative;
    z-index: 2;
  }
  
  .portfolio-header {
    text-align: center;
    margin-bottom: 60px;
  }
  
  .portfolio-title {
    margin: 0 0 20px 0;
    font-family: 'Caveat Brush', cursive;
  }
  
  .portfolio-title .title-small {
    display: block;
    font-size: 24px;
    letter-spacing: 6px;
    color: #FF0000;
    margin-bottom: 10px;
    font-weight: 400;
  }
  
  .portfolio-title .title-large {
    display: block;
    font-size: 80px;
    color: #ffffff;
    line-height: 1;
  }
  
  .portfolio-title .dot {
    color: #FF0000;
  }
  
  .portfolio-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .portfolio-filters {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 60px;
  }
  
  .filter-btn {
    padding: 10px 24px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #ffffff;
    cursor: pointer;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
  }
  
  .filter-btn:hover {
    background: rgba(255, 0, 0, 0.3);
    border-color: #FF0000;
  }
  
  .filter-btn.active {
    background: #FF0000;
    border-color: #FF0000;
    color: white;
  }
  
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 60px;
  }
  
  /* Нестандартные размеры */
  .portfolio-item:nth-child(1) { grid-row: span 1; }
  .portfolio-item:nth-child(2) { grid-row: span 1; transform: translateY(20px); }
  .portfolio-item:nth-child(3) { grid-row: span 1; }
  .portfolio-item:nth-child(4) { grid-row: span 1; transform: translateY(-20px); }
  .portfolio-item:nth-child(5) { grid-row: span 1; }
  .portfolio-item:nth-child(6) { grid-row: span 1; transform: translateY(20px); }
  .portfolio-item:nth-child(7) { grid-row: span 1; }
  .portfolio-item:nth-child(8) { grid-row: span 1; transform: translateY(-15px); }
  .portfolio-item:nth-child(9) { grid-row: span 1; }
  
  /* Показываем все элементы */
  .portfolio-item {
    display: block;
  }
  
  .portfolio-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    cursor: pointer;
  }
  
  .portfolio-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  
  .portfolio-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }
  
  .portfolio-card:hover .portfolio-image {
    transform: scale(1.1);
  }
  
  .portfolio-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }
  
  .portfolio-card:hover .portfolio-overlay {
    opacity: 1;
    visibility: visible;
  }
  
  .overlay-content {
    text-align: center;
    padding: 24px;
    transform: translateY(20px);
    transition: transform 0.4s ease;
  }
  
  .portfolio-card:hover .overlay-content {
    transform: translateY(0);
  }
  
  .service-badge {
    display: inline-block;
    padding: 4px 12px;
    background: #FF0000;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 12px;
    letter-spacing: 0.5px;
  }
  
  .overlay-title {
    font-family: 'Sonsie One', cursive;
    font-size: 20px;
    color: #ffffff;
    margin: 0 0 10px 0;
    line-height: 1.3;
  }
  
  .overlay-description {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 16px 0;
  }
  
  .overlay-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-bottom: 16px;
  }
  
  .overlay-tag {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    padding: 3px 10px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    color: rgba(255, 255, 255, 0.8);
  }
  
  .overlay-footer {
    display: flex;
    justify-content: center;
    gap: 16px;
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .location-icon,
  .duration-icon {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.6);
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Анимация появления */
  .portfolio-item {
    animation: fadeInUp 0.6s ease forwards;
    animation-delay: calc(var(--item-index) * 0.05s);
    opacity: 0;
  }
  
  /* Фильтрация */
  .portfolio-item.hide {
    display: none;
  }
  
  .portfolio-footer {
    text-align: center;
    margin-top: 20px;
  }
  
  .view-all-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    padding: 12px 24px;
    border-bottom: 2px solid rgba(255, 255, 255, 0.5);
    transition: all 0.3s ease;
  }
  
  .view-all-link:hover {
    gap: 16px;
    border-bottom-color: #FF0000;
    color: #FF0000;
  }
  
  /* ========== МЕДИА-ЗАПРОСЫ ========== */
  
  @media (max-width: 1400px) {
    .portfolio-section {
      padding: 100px 0;
    }
    
    .portfolio-title .title-large {
      font-size: 64px;
    }
    
    .portfolio-item:nth-child(2),
    .portfolio-item:nth-child(4),
    .portfolio-item:nth-child(6),
    .portfolio-item:nth-child(8) {
      transform: translateY(0);
    }
  }
  
  @media (max-width: 1024px) {
    .portfolio-section {
      padding: 80px 0;
    }
    
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    
    .portfolio-title .title-large {
      font-size: 56px;
    }
    
    .filter-btn {
      padding: 8px 18px;
      font-size: 12px;
    }
  }
  
  @media (max-width: 768px) {
    .portfolio-section {
      padding: 60px 0;
    }
    
    .portfolio-container {
      padding: 0 20px;
    }
    
    .portfolio-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    
    .portfolio-title .title-small {
      font-size: 18px;
      letter-spacing: 4px;
    }
    
    .portfolio-title .title-large {
      font-size: 48px;
    }
    
    .portfolio-subtitle {
      font-size: 16px;
      padding: 0 16px;
    }
    
    .portfolio-filters {
      gap: 8px;
      margin-bottom: 40px;
    }
    
    .filter-btn {
      padding: 6px 14px;
      font-size: 11px;
    }
    
    .overlay-title {
      font-size: 18px;
    }
  }
  
  @media (max-width: 480px) {
    .portfolio-section {
      padding: 40px 0;
    }
    
    .portfolio-title .title-large {
      font-size: 36px;
    }
    
    .portfolio-header {
      margin-bottom: 40px;
    }
    
    .overlay-content {
      padding: 16px;
    }
    
    .overlay-title {
      font-size: 16px;
    }
    
    .overlay-description {
      font-size: 10px;
    }
  }
</style>

<script>
  (function() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const portfolioItems = document.querySelectorAll('.portfolio-item');
    
    let activeFilter = 'all';
    
    function updateDisplay() {
      portfolioItems.forEach(item => {
        const itemCategory = item.getAttribute('data-category');
        
        if (activeFilter === 'all' || itemCategory === activeFilter) {
          item.classList.remove('hide');
        } else {
          item.classList.add('hide');
        }
      });
    }
    
    // Фильтры
    filterBtns.forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        
        filterBtns.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        
        activeFilter = this.getAttribute('data-filter');
        updateDisplay();
      });
    });
    
    // Инициализация
    updateDisplay();
  })();
</script>