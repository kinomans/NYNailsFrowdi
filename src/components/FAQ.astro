---
// Данные для FAQ
const faqItems = [
  {
    id: 1,
    question: "How long does a gel manicure typically last?",
    answer: "Our gel manicures typically last 2-3 weeks without chipping or peeling. With proper care and regular cuticle oil application, some clients enjoy their gel polish for up to 4 weeks. We use premium brands like CND Shellac and Gelish for maximum durability.",
    category: "Services",
    popular: true
  },
  {
    id: 2,
    question: "Do you offer nail repair services for broken nails?",
    answer: "Yes! We specialize in nail repair using silk wrap, fiberglass, or gel techniques. Most repairs take 15-20 minutes and cost $15-25 depending on the damage. We can also apply a temporary tip if needed.",
    category: "Services",
    popular: true
  },
  {
    id: 3,
    question: "How do I book an appointment?",
    answer: "You can book online through our website, call us at +1 (212) 555-1234, or send a message on WhatsApp. Walk-ins are welcome but we recommend booking in advance, especially for weekends and evenings.",
    category: "Booking",
    popular: true
  },
  {
    id: 4,
    question: "What safety measures do you take for sterilization?",
    answer: "We follow medical-grade sterilization protocols: autoclave sterilization for all metal tools, single-use files and buffers for each client, hospital-grade disinfectants for surfaces, and our technicians wear masks and gloves. Your safety is our priority.",
    category: "Safety",
    popular: false
  },
  {
    id: 5,
    question: "Do you offer services for men?",
    answer: "Absolutely! Men's grooming services include basic manicure, nail shaping, cuticle care, buffing, and paraffin treatments. No polish required unless requested. We create a comfortable, judgment-free environment for everyone.",
    category: "Services",
    popular: false
  },
  {
    id: 6,
    question: "What's your cancellation policy?",
    answer: "We require 24-hour notice for cancellations or rescheduling. Late cancellations or no-shows may be charged 50% of the service price. You can cancel online, by phone, or via WhatsApp.",
    category: "Policy",
    popular: false
  },
  {
    id: 7,
    question: "Do you offer gift certificates?",
    answer: "Yes! Digital and physical gift cards are available starting at $25. Perfect for birthdays, holidays, or treating someone special. Purchase online or in-salon.",
    category: "Booking",
    popular: false
  },
  {
    id: 8,
    question: "What nail brands do you use?",
    answer: "We use premium professional brands: OPI, CND Shellac, Gelish, Kiara Sky, and Japanese gels. All products are authentic, non-toxic, and gentle on natural nails.",
    category: "Services",
    popular: true
  }
];

// Категории для фильтрации
const categories = ["All", "Services", "Booking", "Safety", "Policy"];
---

<section class="faq-section">
  <div class="faq-container">
    <!-- Заголовок секции -->
    <div class="faq-header">
      <h2 class="faq-title">
        <span class="title-small">GOT QUESTIONS?</span>
        <span class="title-large">WE'VE GOT<span class="dot">.</span></span>
      </h2>
      <p class="faq-subtitle">
        Everything you need to know about our services, booking, and policies.<br>
        Can't find your answer? Just ask!
      </p>
    </div>
    
    <!-- Фильтры категорий -->
    <div class="faq-filters">
      {categories.map(category => (
        <button class="filter-chip" data-category={category === "All" ? "all" : category}>
          {category}
        </button>
      ))}
    </div>
    
    <!-- Сетка FAQ -->
    <div class="faq-grid" id="faqGrid">
      {faqItems.map((item, index) => (
        <div 
          class="faq-card" 
          data-category={item.category}
          data-id={item.id}
          style={`--card-index: ${index}`}
        >
          <button class="faq-question" aria-expanded="false">
            <div class="question-content">
              <div class="question-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <line x1="12" y1="17" x2="12.01" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
              <span class="question-text">{item.question}</span>
            </div>
            <div class="question-arrow">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer">
            <div class="answer-content">
              <p class="answer-text">{item.answer}</p>
              {item.popular && (
                <span class="popular-badge">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M12 2L15 8.5L22 9.5L17 14L18.5 21L12 17.5L5.5 21L7 14L2 9.5L9 8.5L12 2z" fill="currentColor"/>
                  </svg>
                  Most popular
                </span>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Дополнительный CTA -->
    <div class="faq-footer">
      <div class="footer-content">
        <div class="footer-icon">💬</div>
        <div class="footer-text">
          <h3>Still have questions?</h3>
          <p>Our team is here to help you 7 days a week</p>
        </div>
        <a href="#" class="contact-link">
          Contact us
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .faq-section {
    position: relative;
    width: 100%;
    padding: 120px 0;
    background: linear-gradient(135deg, #f8f8f8 0%, #ffffff 100%);
    overflow: hidden;
  }
  
  .faq-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 20% 30%, rgba(255, 0, 0, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }
  
  .faq-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 26px;
    position: relative;
    z-index: 2;
  }
  
  .faq-header {
    text-align: center;
    margin-bottom: 60px;
  }
  
  .faq-title {
    margin: 0 0 20px 0;
    font-family: 'Caveat Brush', cursive;
  }
  
  .faq-title .title-small {
    display: block;
    font-size: 24px;
    letter-spacing: 6px;
    color: #FF0000;
    margin-bottom: 10px;
    font-weight: 400;
  }
  
  .faq-title .title-large {
    display: block;
    font-size: 80px;
    color: #1E1E1E;
    line-height: 1;
  }
  
  .faq-title .dot {
    color: #FF0000;
  }
  
  .faq-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    color: #666;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }
  
  /* Фильтры */
  .faq-filters {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 50px;
  }
  
  .filter-chip {
    padding: 8px 20px;
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #666;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .filter-chip:hover {
    background: #FF0000;
    border-color: #FF0000;
    color: white;
    transform: translateY(-2px);
  }
  
  .filter-chip.active {
    background: #FF0000;
    border-color: #FF0000;
    color: white;
  }
  
  /* Сетка FAQ */
  .faq-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 60px;
  }
  
  /* Карточка вопроса */
  .faq-card {
    background: white;
    border-radius: 24px;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    border: 1px solid #e0e0e0;
  }
  
  .faq-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }
  
  .faq-question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 28px;
    background: white;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: all 0.3s ease;
  }
  
  .question-content {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: 1;
  }
  
  .question-icon {
    flex-shrink: 0;
    color: #FF0000;
    transition: transform 0.3s ease;
  }
  
  .faq-card:hover .question-icon {
    transform: scale(1.05);
  }
  
  .question-text {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #1E1E1E;
    line-height: 1.4;
  }
  
  .question-arrow {
    flex-shrink: 0;
    color: #999;
    transition: all 0.3s ease;
  }
  
  .faq-card.active .question-arrow {
    transform: rotate(180deg);
    color: #FF0000;
  }
  
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    background: #fafafa;
    border-top: 1px solid transparent;
  }
  
  .faq-card.active .faq-answer {
    max-height: 500px;
    border-top-color: #e0e0e0;
  }
  
  .answer-content {
    padding: 24px 28px;
    position: relative;
  }
  
  .answer-text {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: #555;
    margin: 0 0 16px 0;
  }
  
  .popular-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: rgba(255, 0, 0, 0.1);
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: #FF0000;
  }
  
  /* Footer CTA */
  .faq-footer {
    background: linear-gradient(135deg, #FF0000 0%, #cc0000 100%);
    border-radius: 32px;
    padding: 40px;
    overflow: hidden;
    position: relative;
  }
  
  .faq-footer::before {
    content: '';
    position: absolute;
    top: -30%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  
  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
    position: relative;
    z-index: 2;
  }
  
  .footer-icon {
    font-size: 48px;
    filter: drop-shadow(0 5px 10px rgba(0, 0, 0, 0.2));
  }
  
  .footer-text h3 {
    font-family: 'Sonsie One', cursive;
    font-size: 24px;
    color: white;
    margin: 0 0 8px 0;
  }
  
  .footer-text p {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
  }
  
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: white;
    color: #FF0000;
    padding: 12px 28px;
    border-radius: 100px;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 16px;
    transition: all 0.3s ease;
  }
  
  .contact-link:hover {
    gap: 16px;
    transform: scale(1.02);
  }
  
  /* Анимация появления карточек */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .faq-card {
    animation: fadeInUp 0.4s ease forwards;
    animation-delay: calc(var(--card-index) * 0.05s);
    opacity: 0;
  }
  
  /* Фильтрация */
  .faq-card.hide {
    display: none;
  }
  
  /* ========== МЕДИА-ЗАПРОСЫ ========== */
  
  @media (max-width: 1024px) {
    .faq-section {
      padding: 80px 0;
    }
    
    .faq-title .title-large {
      font-size: 56px;
    }
    
    .question-text {
      font-size: 16px;
    }
  }
  
  @media (max-width: 768px) {
    .faq-section {
      padding: 60px 0;
    }
    
    .faq-container {
      padding: 0 20px;
    }
    
    .faq-title .title-small {
      font-size: 18px;
      letter-spacing: 4px;
    }
    
    .faq-title .title-large {
      font-size: 48px;
    }
    
    .faq-subtitle {
      font-size: 16px;
      padding: 0 16px;
    }
    
    .faq-question {
      padding: 18px 20px;
    }
    
    .question-content {
      gap: 12px;
    }
    
    .question-text {
      font-size: 15px;
    }
    
    .answer-content {
      padding: 20px;
    }
    
    .answer-text {
      font-size: 14px;
    }
    
    .footer-content {
      flex-direction: column;
      text-align: center;
    }
    
    .footer-text h3 {
      font-size: 20px;
    }
    
    .filter-chip {
      padding: 6px 16px;
      font-size: 12px;
    }
  }
  
  @media (max-width: 480px) {
    .faq-section {
      padding: 40px 0;
    }
    
    .faq-title .title-large {
      font-size: 36px;
    }
    
    .faq-header {
      margin-bottom: 40px;
    }
    
    .question-text {
      font-size: 14px;
    }
    
    .question-icon svg {
      width: 20px;
      height: 20px;
    }
    
    .faq-filters {
      gap: 8px;
      margin-bottom: 32px;
    }
    
    .popular-badge {
      font-size: 10px;
    }
  }
</style>

<script>
  // Аккордеон логика
  const faqCards = document.querySelectorAll('.faq-card');
  
  faqCards.forEach(card => {
    const questionBtn = card.querySelector('.faq-question');
    
    questionBtn.addEventListener('click', () => {
      // Закрываем другие открытые карточки
      faqCards.forEach(otherCard => {
        if (otherCard !== card && otherCard.classList.contains('active')) {
          otherCard.classList.remove('active');
          const otherBtn = otherCard.querySelector('.faq-question');
          if (otherBtn) otherBtn.setAttribute('aria-expanded', 'false');
        }
      });
      
      // Открываем/закрываем текущую
      card.classList.toggle('active');
      const isExpanded = card.classList.contains('active');
      questionBtn.setAttribute('aria-expanded', isExpanded);
    });
  });
  
  // Фильтрация по категориям
  const filterChips = document.querySelectorAll('.filter-chip');
  const faqItems = document.querySelectorAll('.faq-card');
  
  filterChips.forEach(chip => {
    chip.addEventListener('click', () => {
      // Убираем active у всех чипов
      filterChips.forEach(c => c.classList.remove('active'));
      // Добавляем active текущему
      chip.classList.add('active');
      
      const filterValue = chip.getAttribute('data-category');
      
      faqItems.forEach(item => {
        if (filterValue === 'all' || item.getAttribute('data-category') === filterValue) {
          item.classList.remove('hide');
          // Добавляем анимацию появления
          item.style.animation = 'fadeInUp 0.4s ease forwards';
        } else {
          item.classList.add('hide');
        }
      });
    });
  });
</script>