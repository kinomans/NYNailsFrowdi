---
// Контактная информация
const contactInfo = {
  phone: "+1 (212) 555-1234",
  phoneFormatted: "+12125551234",
  whatsapp: "+1 (212) 555-1234",
  email: "hello@nynails.com",
  address: "123 Fifth Avenue, New York, NY 10001",
  addressLink: "https://maps.google.com/?q=123+Fifth+Avenue+New+York+NY",
  instagram: "@nynails",
  instagramLink: "#",
  tiktok: "@nynails",
  tiktokLink: "#"
};

const hours = [
  { day: "Monday - Friday", hours: "9:00 AM — 9:00 PM" },
  { day: "Saturday", hours: "10:00 AM — 8:00 PM" },
  { day: "Sunday", hours: "10:00 AM — 6:00 PM" }
];

const servicesList = [
  "Classic Manicure", "Gel Polish", "Nail Extensions",
  "Nail Art Design", "Pedicure", "Dip Powder"
];
---

<section class="contact-section">
  <div class="contact-container">
    <!-- Заголовок секции -->
    <div class="contact-header">
      <h2 class="contact-title">
        <span class="title-small">GET IN TOUCH</span>
        <span class="title-large">BOOK NOW<span class="dot">.</span></span>
      </h2>
      <p class="contact-subtitle">
        Ready for your perfect nails? Reach out to us anytime.<br>
        We're here to bring your nail dreams to life.
      </p>
    </div>
    
    <div class="contact-grid">
      <!-- ЛЕВАЯ КОЛОНКА: Контакты и соцсети -->
      <div class="contact-info-card">
        <div class="info-header">
          <div class="info-icon-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="1.5" fill="none"/>
            </svg>
          </div>
          <h3 class="info-title">Contact Us</h3>
        </div>
        
        <div class="contact-methods">
          <a href={`tel:${contactInfo.phoneFormatted}`} class="contact-item">
            <div class="contact-icon phone">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="1.5" fill="none"/>
              </svg>
            </div>
            <div class="contact-details">
              <span class="contact-label">Call us</span>
              <span class="contact-value">{contactInfo.phone}</span>
            </div>
          </a>
          
          <a href={`https://wa.me/${contactInfo.phoneFormatted}`} class="contact-item" target="_blank" rel="noopener noreferrer">
            <div class="contact-icon whatsapp">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M21.5 11.5a9 9 0 0 1-9 9c-1.5 0-2.9-.4-4.2-1L3 20l1.5-5.3A9 9 0 1 1 12.5 20.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M8.5 9.5h.01M15.5 9.5h.01" stroke="currentColor" stroke-width="2"/>
                <circle cx="12" cy="13.5" r="3.5" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </div>
            <div class="contact-details">
              <span class="contact-label">WhatsApp</span>
              <span class="contact-value">Message us</span>
            </div>
          </a>
          
          <a href={`mailto:${contactInfo.email}`} class="contact-item">
            <div class="contact-icon email">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="1.5" fill="none"/>
              </svg>
            </div>
            <div class="contact-details">
              <span class="contact-label">Email us</span>
              <span class="contact-value">{contactInfo.email}</span>
            </div>
          </a>
          
          <div class="contact-item location">
            <div class="contact-icon location">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="12" cy="9" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
              </svg>
            </div>
            <div class="contact-details">
              <span class="contact-label">Visit us</span>
              <a href={contactInfo.addressLink} class="contact-value address" target="_blank" rel="noopener noreferrer">{contactInfo.address}</a>
            </div>
          </div>
        </div>
        
        <!-- Социальные сети -->
        <div class="social-section">
          <div class="social-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M19.4 4.6C18.4 3.6 17 3 15.5 3h-7C6 3 3 6 3 8.5v7C3 18 6 21 8.5 21h7c2.5 0 5.5-3 5.5-5.5v-7c0-1.5-.6-2.9-1.6-3.9z" stroke="currentColor" stroke-width="1.5" fill="none"/>
            </svg>
            <span>Follow us</span>
          </div>
          <div class="social-links">
            <a href={contactInfo.instagramLink} class="social-link" target="_blank" rel="noopener noreferrer">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
              </svg>
              <span>Instagram</span>
            </a>
            <a href={contactInfo.tiktokLink} class="social-link" target="_blank" rel="noopener noreferrer">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M19.5 5.5c-1.8 0-3.5-1-4.5-2.5v10c0 2.5-2 4.5-4.5 4.5S6 15.5 6 13s2-4.5 4.5-4.5c.3 0 .6 0 .9.1V12c-.3-.1-.6-.1-.9-.1-1.4 0-2.5 1.1-2.5 2.5s1.1 2.5 2.5 2.5 2.5-1.1 2.5-2.5V2.5h2.5c0 2 1.5 3.5 3.5 3.5v2z" stroke="currentColor" stroke-width="1.5" fill="none"/>
              </svg>
              <span>TikTok</span>
            </a>
          </div>
        </div>
      </div>
      
      <!-- ПРАВАЯ КОЛОНКА: Часы работы и карта -->
      <div class="contact-info-card">
        <div class="info-header">
          <div class="info-icon-wrapper">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
              <polyline points="12 6 12 12 16 14" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="info-title">Hours & Location</h3>
        </div>
        
        <div class="hours-list">
          {hours.map((slot) => (
            <div class="hour-item">
              <span class="hour-day">{slot.day}</span>
              <span class="hour-time">{slot.hours}</span>
            </div>
          ))}
        </div>
        
        <!-- Мини-карта -->
        <div class="map-wrapper">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3024.2219901290355!2d-74.00369368400567!3d40.713129379330185!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c25a316bb7ed0b%3A0xb89d1fe6bc499443!2sDowntown%20Conference%20Center!5e0!3m2!1sen!2sus!4v1641234567890!5m2!1sen!2sus"
            width="100%" 
            height="200" 
            style="border:0; border-radius: 24px;" 
            allowfullscreen="" 
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="NY Nails Salon Location Map"
            class="map-iframe"
          ></iframe>
          <a href={contactInfo.addressLink} class="map-link" target="_blank" rel="noopener noreferrer">
            Get directions →
          </a>
        </div>
      </div>
    </div>
    
    <!-- КРЕАТИВНЫЙ CTA БЛОК -->
    <div class="cta-block">
      <div class="cta-content">
        <div class="cta-icon">💅</div>
        <h3 class="cta-title">Ready for your dream nails?</h3>
        <p class="cta-text">Book your appointment now and get 10% off your first visit!</p>
        <a href="#" class="cta-button">
          Book your appointment
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    position: relative;
    width: 100%;
    padding: 120px 0;
    background: #ffffff;
    overflow: hidden;
  }
  
  .contact-section::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255, 0, 0, 0.05) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  
  .contact-section::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -5%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255, 0, 0, 0.03) 0%, transparent 70%);
    pointer-events: none;
  }
  
  .contact-container {
    max-width: 1520px;
    margin: 0 auto;
    padding: 0 26px;
    position: relative;
    z-index: 2;
  }
  
  .contact-header {
    text-align: center;
    margin-bottom: 60px;
  }
  
  .contact-title {
    margin: 0 0 20px 0;
    font-family: 'Caveat Brush', cursive;
  }
  
  .contact-title .title-small {
    display: block;
    font-size: 24px;
    letter-spacing: 6px;
    color: #FF0000;
    margin-bottom: 10px;
    font-weight: 400;
  }
  
  .contact-title .title-large {
    display: block;
    font-size: 80px;
    color: #1E1E1E;
    line-height: 1;
  }
  
  .contact-title .dot {
    color: #FF0000;
  }
  
  .contact-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    color: #666;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
    margin-bottom: 60px;
  }
  
  .contact-info-card {
    background: white;
    border-radius: 32px;
    padding: 40px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .contact-info-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 30px 50px rgba(0, 0, 0, 0.1);
  }
  
  .info-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 2px solid #FF0000;
  }
  
  .info-icon-wrapper {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, #FF0000, #cc0000);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }
  
  .info-title {
    font-family: 'Sonsie One', cursive;
    font-size: 28px;
    color: #1E1E1E;
    margin: 0;
  }
  
  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 32px;
  }
  
  .contact-item {
    display: flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
    padding: 12px;
    border-radius: 20px;
    transition: all 0.3s ease;
    background: #f8f8f8;
  }
  
  .contact-item:hover {
    background: #FF0000;
    transform: translateX(8px);
  }
  
  .contact-icon {
    width: 48px;
    height: 48px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }
  
  .contact-icon.phone {
    background: rgba(255, 0, 0, 0.1);
    color: #FF0000;
  }
  
  .contact-icon.whatsapp {
    background: rgba(37, 211, 102, 0.1);
    color: #25D366;
  }
  
  .contact-icon.email {
    background: rgba(0, 119, 255, 0.1);
    color: #0077FF;
  }
  
  .contact-icon.location {
    background: rgba(255, 193, 7, 0.1);
    color: #FFC107;
  }
  
  .contact-item:hover .contact-icon {
    background: white;
    transform: scale(1.05);
  }
  
  .contact-details {
    flex: 1;
  }
  
  .contact-label {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #999;
    margin-bottom: 4px;
  }
  
  .contact-value {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #1E1E1E;
    text-decoration: none;
  }
  
  .contact-item:hover .contact-label,
  .contact-item:hover .contact-value {
    color: white;
  }
  
  .contact-value.address {
    color: #1E1E1E;
    text-decoration: underline;
  }
  
  .contact-item:hover .contact-value.address {
    color: white;
  }
  
  .social-section {
    padding-top: 20px;
    border-top: 1px solid #e0e0e0;
  }
  
  .social-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #666;
  }
  
  .social-links {
    display: flex;
    gap: 16px;
  }
  
  .social-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: #f8f8f8;
    border-radius: 100px;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #1E1E1E;
    transition: all 0.3s ease;
  }
  
  .social-link:hover {
    background: #FF0000;
    color: white;
    transform: translateY(-3px);
  }
  
  .hours-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }
  
  .hour-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid #e0e0e0;
  }
  
  .hour-day {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    color: #1E1E1E;
  }
  
  .hour-time {
    font-family: 'Inter', sans-serif;
    color: #FF0000;
    font-weight: 500;
  }
  
  .map-wrapper {
    margin-top: 20px;
  }
  
  .map-iframe {
    width: 100%;
    height: 200px;
    border-radius: 24px;
    margin-bottom: 12px;
  }
  
  .map-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #FF0000;
    text-decoration: none;
    font-weight: 500;
    transition: gap 0.3s ease;
  }
  
  .map-link:hover {
    gap: 12px;
  }
  
  .cta-block {
    background: linear-gradient(135deg, #FF0000 0%, #cc0000 100%);
    border-radius: 32px;
    padding: 50px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  
  .cta-block::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  
  .cta-block::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  
  .cta-content {
    position: relative;
    z-index: 2;
  }
  
  .cta-icon {
    font-size: 60px;
    margin-bottom: 16px;
  }
  
  .cta-title {
    font-family: 'Sonsie One', cursive;
    font-size: 32px;
    color: white;
    margin: 0 0 12px 0;
  }
  
  .cta-text {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 24px 0;
  }
  
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: white;
    color: #FF0000;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 16px;
    transition: all 0.3s ease;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }
  
  .cta-button:hover {
    gap: 16px;
    transform: scale(1.02);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
  }
  
  @media (max-width: 1024px) {
    .contact-section {
      padding: 80px 0;
    }
    
    .contact-title .title-large {
      font-size: 56px;
    }
    
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    
    .info-title {
      font-size: 24px;
    }
  }
  
  @media (max-width: 768px) {
    .contact-section {
      padding: 60px 0;
    }
    
    .contact-container {
      padding: 0 20px;
    }
    
    .contact-title .title-small {
      font-size: 18px;
      letter-spacing: 4px;
    }
    
    .contact-title .title-large {
      font-size: 48px;
    }
    
    .contact-subtitle {
      font-size: 16px;
      padding: 0 16px;
    }
    
    .contact-info-card {
      padding: 28px;
    }
    
    .info-icon-wrapper {
      width: 48px;
      height: 48px;
    }
    
    .info-title {
      font-size: 22px;
    }
    
    .cta-block {
      padding: 32px 24px;
    }
    
    .cta-title {
      font-size: 24px;
    }
    
    .cta-text {
      font-size: 14px;
    }
    
    .cta-button {
      padding: 12px 24px;
      font-size: 14px;
    }
  }
  
  @media (max-width: 480px) {
    .contact-section {
      padding: 40px 0;
    }
    
    .contact-title .title-large {
      font-size: 36px;
    }
    
    .contact-header {
      margin-bottom: 40px;
    }
    
    .social-links {
      flex-direction: column;
    }
    
    .social-link {
      justify-content: center;
    }
    
    .hour-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>