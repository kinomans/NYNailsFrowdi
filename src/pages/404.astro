---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Page Not Found | NY Nails";
const pageDescription = "Oops! The page you're looking for doesn't exist. But don't worry — your perfect nails are just a click away.";

// Популярные услуги для навигации
const popularServices = [
  { name: "Gel Polish", slug: "gel-polish", icon: "fa-droplet" },
  { name: "Nail Art", slug: "nail-art", icon: "fa-palette" },
  { name: "Classic Manicure", slug: "classic-manicure", icon: "fa-hand-peace" },
  { name: "Pedicure", slug: "pedicure", icon: "fa-shoe-prints" }
];

// Районы
const areas = [
  { name: "Manhattan", slug: "manhattan" },
  { name: "Brooklyn", slug: "brooklyn" },
  { name: "Queens", slug: "queens" },
  { name: "Bronx", slug: "bronx" },
  { name: "Staten Island", slug: "staten-island" }
];
---

<BaseLayout title={pageTitle} description={pageDescription} pageType="error">
  <main>
    <!-- 404 Hero секция -->
    <section class="error-hero">
      <div class="error-content">
        <div class="error-code">
          <span class="code-digit">4</span>
          <span class="code-icon">💅</span>
          <span class="code-digit">4</span>
        </div>
        <h1 class="error-title">Oops! Page Not Found</h1>
        <p class="error-subtitle">The page you're looking for seems to have wandered off for a manicure.<br>But don't worry — we'll help you find your way.</p>
        <div class="error-actions">
          <a href="/" class="btn-primary">
            <i class="fas fa-home"></i> Back to Home
          </a>
          <a href="/services" class="btn-secondary">
            Explore Services <i class="fas fa-arrow-right"></i>
          </a>
        </div>
      </div>
      
      <!-- Декоративные элементы -->
      <div class="error-decor">
        <div class="decor-circle circle-1"></div>
        <div class="decor-circle circle-2"></div>
        <div class="decor-circle circle-3"></div>
        <div class="decor-nail nail-1">💅</div>
        <div class="decor-nail nail-2">✨</div>
        <div class="decor-nail nail-3">💎</div>
      </div>
    </section>

    <!-- Быстрые ссылки -->
    <section class="quick-links">
      <div class="links-container">
        <h2>Here's What You Might Be Looking For</h2>
        
        <div class="links-grid">
          <!-- Популярные услуги -->
          <div class="links-card">
            <div class="card-header">
              <i class="fas fa-spa"></i>
              <h3>Our Services</h3>
            </div>
            <ul class="links-list">
              {popularServices.map(service => (
                <li>
                  <a href={`/services/${service.slug}`}>
                    <i class={`fas ${service.icon}`}></i>
                    {service.name}
                    <i class="fas fa-arrow-right link-arrow"></i>
                  </a>
                </li>
              ))}
              <li class="view-all">
                <a href="/services">
                  View All Services <i class="fas fa-arrow-right"></i>
                </a>
              </li>
            </ul>
          </div>
          
          <!-- Районы -->
          <div class="links-card">
            <div class="card-header">
              <i class="fas fa-location-dot"></i>
              <h3>Our Locations</h3>
            </div>
            <ul class="links-list locations-list">
              {areas.map(area => (
                <li>
                  <a href={`/areas/${area.slug}`}>
                    <i class="fas fa-map-pin"></i>
                    {area.name}
                    <i class="fas fa-arrow-right link-arrow"></i>
                  </a>
                </li>
              ))}
            </ul>
          </div>
          
          <!-- Быстрая помощь -->
          <div class="links-card">
            <div class="card-header">
              <i class="fas fa-headset"></i>
              <h3>Need Help?</h3>
            </div>
            <div class="help-content">
              <p>Our team is here to assist you</p>
              <div class="help-buttons">
                <a href="/contact" class="help-btn">
                  <i class="fas fa-envelope"></i> Contact Us
                </a>
                <a href="/booking" class="help-btn primary">
                  <i class="fas fa-calendar-check"></i> Book Now
                </a>
              </div>
              <div class="emergency-contact">
                <span>Or call us directly:</span>
                <a href="tel:+12125551234" class="phone-link">
                  <i class="fas fa-phone"></i> +1 (212) 555-1234
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Поиск по сайту -->
    <section class="search-section">
      <div class="search-container">
        <div class="search-icon">🔍</div>
        <h2>Can't Find What You're Looking For?</h2>
        <p>Try searching our site — we'll help you find the perfect nail service</p>
        <form class="search-form" action="/search" method="get">
          <div class="search-wrapper">
            <input 
              type="text" 
              name="q" 
              placeholder="Search for services, locations, or articles..." 
              aria-label="Search"
            />
            <button type="submit">
              <i class="fas fa-search"></i> Search
            </button>
          </div>
        </form>
      </div>
    </section>

    <!-- Предложение записаться -->
    <section class="error-cta">
      <div class="cta-content">
        <div class="cta-icon">💅</div>
        <h2>Still Here? Let's Get You Some Gorgeous Nails Instead!</h2>
        <p>Book your appointment today and let our artists create something beautiful for you</p>
        <div class="cta-buttons">
          <a href="/booking" class="btn-primary">Book Now →</a>
          <a href="/portfolio" class="btn-secondary">View Portfolio</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* 404 Hero секция */
  .error-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
    overflow: hidden;
  }
  
  .error-content {
    position: relative;
    z-index: 10;
    max-width: 800px;
    padding: 0 20px;
  }
  
  .error-code {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 30px;
    font-family: 'Caveat Brush', cursive;
  }
  
  .code-digit {
    font-size: 120px;
    font-weight: bold;
    color: #FF0000;
    text-shadow: 0 0 30px rgba(255,0,0,0.3);
    animation: float 3s ease-in-out infinite;
  }
  
  .code-icon {
    font-size: 80px;
    animation: spin 4s ease-in-out infinite;
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  
  @keyframes spin {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(10deg); }
  }
  
  .error-title {
    font-family: 'Sonsie One', cursive;
    font-size: 48px;
    color: white;
    margin-bottom: 20px;
  }
  
  .error-subtitle {
    font-size: 18px;
    color: rgba(255,255,255,0.8);
    margin-bottom: 40px;
    line-height: 1.6;
  }
  
  .error-actions {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }
  
  .btn-primary {
    background: #FF0000;
    color: white;
  }
  
  .btn-primary:hover {
    background: #cc0000;
    transform: translateY(-3px);
    gap: 12px;
  }
  
  .btn-secondary {
    background: transparent;
    color: white;
    border: 2px solid white;
  }
  
  .btn-secondary:hover {
    background: white;
    color: #FF0000;
    transform: translateY(-3px);
    gap: 12px;
  }
  
  /* Декоративные элементы */
  .error-decor {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  
  .decor-circle {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,0,0,0.1) 0%, transparent 70%);
  }
  
  .circle-1 {
    width: 400px;
    height: 400px;
    top: -200px;
    right: -100px;
    animation: float 20s ease-in-out infinite;
  }
  
  .circle-2 {
    width: 300px;
    height: 300px;
    bottom: -150px;
    left: -100px;
    animation: float 15s ease-in-out infinite reverse;
  }
  
  .circle-3 {
    width: 200px;
    height: 200px;
    top: 50%;
    left: 20%;
    animation: float 18s ease-in-out infinite;
  }
  
  .decor-nail {
    position: absolute;
    font-size: 30px;
    opacity: 0.3;
    animation: float 6s ease-in-out infinite;
  }
  
  .nail-1 {
    top: 20%;
    right: 15%;
    animation-delay: 0s;
  }
  
  .nail-2 {
    bottom: 25%;
    left: 10%;
    animation-delay: 1s;
  }
  
  .nail-3 {
    top: 60%;
    right: 20%;
    animation-delay: 2s;
  }
  
  /* Быстрые ссылки */
  .quick-links {
    padding: 80px 0;
    background: #f8f8f8;
  }
  
  .links-container {
    max-width: 1520px;
    margin: 0 auto;
    padding: 0 26px;
  }
  
  .links-container > h2 {
    text-align: center;
    font-family: 'Caveat Brush', cursive;
    font-size: 40px;
    color: #1E1E1E;
    margin-bottom: 50px;
  }
  
  .links-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  
  .links-card {
    background: white;
    border-radius: 28px;
    padding: 32px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }
  
  .links-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  }
  
  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 2px solid #FF0000;
  }
  
  .card-header i {
    font-size: 32px;
    color: #FF0000;
  }
  
  .card-header h3 {
    font-family: 'Sonsie One', cursive;
    font-size: 24px;
    color: #1E1E1E;
    margin: 0;
  }
  
  .links-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .links-list li {
    margin-bottom: 12px;
  }
  
  .links-list a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    color: #555;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    transition: all 0.3s ease;
  }
  
  .links-list a i:first-child {
    width: 24px;
    color: #FF0000;
  }
  
  .link-arrow {
    margin-left: auto;
    opacity: 0;
    transition: all 0.3s ease;
  }
  
  .links-list a:hover {
    color: #FF0000;
    transform: translateX(5px);
  }
  
  .links-list a:hover .link-arrow {
    opacity: 1;
    transform: translateX(0);
  }
  
  .locations-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }
  
  .view-all {
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid #e0e0e0;
  }
  
  .view-all a {
    color: #FF0000;
    font-weight: 600;
  }
  
  /* Help секция */
  .help-content p {
    font-family: 'Inter', sans-serif;
    color: #666;
    margin-bottom: 20px;
  }
  
  .help-buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }
  
  .help-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 20px;
    background: #f0f0f0;
    border-radius: 100px;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    color: #555;
    transition: all 0.3s ease;
  }
  
  .help-btn.primary {
    background: #FF0000;
    color: white;
  }
  
  .help-btn:hover {
    transform: translateY(-2px);
    gap: 12px;
  }
  
  .emergency-contact {
    text-align: center;
    padding-top: 16px;
    border-top: 1px solid #e0e0e0;
  }
  
  .emergency-contact span {
    font-size: 12px;
    color: #999;
    display: block;
    margin-bottom: 8px;
  }
  
  .phone-link {
    font-size: 18px;
    font-weight: 600;
    color: #FF0000;
    text-decoration: none;
  }
  
  /* Поиск */
  .search-section {
    padding: 80px 0;
    background: white;
  }
  
  .search-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 26px;
    text-align: center;
  }
  
  .search-icon {
    font-size: 60px;
    margin-bottom: 20px;
  }
  
  .search-container h2 {
    font-family: 'Caveat Brush', cursive;
    font-size: 36px;
    color: #1E1E1E;
    margin-bottom: 16px;
  }
  
  .search-container p {
    font-size: 16px;
    color: #666;
    margin-bottom: 30px;
  }
  
  .search-wrapper {
    display: flex;
    gap: 12px;
    background: #f8f8f8;
    border-radius: 100px;
    padding: 6px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }
  
  .search-wrapper input {
    flex: 1;
    padding: 14px 20px;
    border: none;
    background: transparent;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    outline: none;
  }
  
  .search-wrapper button {
    padding: 12px 28px;
    background: #FF0000;
    color: white;
    border: none;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .search-wrapper button:hover {
    background: #cc0000;
    transform: translateY(-2px);
  }
  
  /* CTA */
  .error-cta {
    padding: 80px 0;
    background: linear-gradient(135deg, #FF0000 0%, #cc0000 100%);
    color: white;
    text-align: center;
  }
  
  .cta-icon {
    font-size: 60px;
    margin-bottom: 20px;
  }
  
  .error-cta h2 {
    font-family: 'Caveat Brush', cursive;
    font-size: 48px;
    margin-bottom: 16px;
  }
  
  .error-cta p {
    font-size: 18px;
    margin-bottom: 32px;
    opacity: 0.9;
  }
  
  .cta-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
  }
  
  .error-cta .btn-primary {
    background: white;
    color: #FF0000;
  }
  
  .error-cta .btn-secondary {
    background: transparent;
    color: white;
    border: 2px solid white;
  }
  
  /* ========== АДАПТИВНОСТЬ ========== */
  
  @media (max-width: 1024px) {
    .error-code .code-digit {
      font-size: 100px;
    }
    
    .code-icon {
      font-size: 60px;
    }
    
    .links-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 768px) {
    .error-title {
      font-size: 36px;
    }
    
    .error-subtitle {
      font-size: 16px;
    }
    
    .error-actions {
      flex-direction: column;
      align-items: center;
    }
    
    .links-grid {
      grid-template-columns: 1fr;
    }
    
    .links-container > h2 {
      font-size: 32px;
    }
    
    .search-container h2 {
      font-size: 28px;
    }
    
    .search-wrapper {
      flex-direction: column;
      border-radius: 28px;
    }
    
    .search-wrapper button {
      width: 100%;
    }
    
    .error-cta h2 {
      font-size: 32px;
    }
    
    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }
  }
  
  @media (max-width: 480px) {
    .error-code .code-digit {
      font-size: 60px;
    }
    
    .code-icon {
      font-size: 40px;
    }
    
    .error-title {
      font-size: 28px;
    }
    
    .locations-list {
      grid-template-columns: 1fr;
    }
  }
</style>