---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = "Nail Salon Brooklyn | Premium Manicure & Nail Art in BK";
const pageDescription = "Experience luxury nail care in Brooklyn. Professional manicure, gel polish, nail art & extensions in Williamsburg, DUMBO & beyond. Book your appointment today!";

const areaData = {
  name: "Brooklyn",
  slug: "brooklyn",
  heroTitle: "BROOKLYN",
  heroSubtitle: "Creative Nail Art in the Heart of BK",
  description: "Brooklyn's creative spirit meets our expert nail artistry. From Williamsburg's trendsetters to DUMBO's artists, we bring unique nail designs to the city's most vibrant borough. Our Brooklyn location combines urban energy with premium nail care, offering everything from classic manicures to avant-garde nail art that reflects your individual style.",
  imageHero: "/images/brooklyn-hero.png",
  stats: [
    { value: "4.9", label: "Google Rating" },
    { value: "500+", label: "Happy Clients" },
    { value: "8+", label: "Expert Artists" },
    { value: "30+", label: "5-Star Reviews" }
  ],
  features: [
    { icon: "fa-location-dot", title: "Easy Access", text: "Near subway stations in Williamsburg" },
    { icon: "fa-calendar", title: "Weekend Hours", text: "Open Saturday & Sunday" },
    { icon: "fa-star", title: "Trendy Designs", text: "Custom nail art for every style" },
    { icon: "fa-shield-heart", title: "Eco-Friendly", text: "Vegan & cruelty-free products" }
  ],
  mapEmbed: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3024.2219901290355!2d-73.9442!3d40.6782!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c25a316bb7ed0b%3A0xb89d1fe6bc499443!2sBrooklyn!5e0!3m2!1sen!2sus!4v1641234567890!5m2!1sen!2sus"
};

const servicesInArea = [
  { name: "Classic Manicure", price: "$35", duration: "45 min", slug: "classic-manicure", popular: true },
  { name: "Gel Polish", price: "$50", duration: "60 min", slug: "gel-polish", popular: true },
  { name: "Nail Extensions", price: "$75", duration: "90-120 min", slug: "nail-extensions", popular: false },
  { name: "Nail Art Design", price: "$45+", duration: "60-90 min", slug: "nail-art", popular: true },
  { name: "Pedicure", price: "$55", duration: "60 min", slug: "pedicure", popular: false },
  { name: "Dip Powder", price: "$55", duration: "60-75 min", slug: "dip-powder", popular: false }
];

const areaTestimonials = [
  { name: "Jessica M.", location: "Williamsburg", text: "The nail art here is incredible! Best salon in Brooklyn.", rating: 5 },
  { name: "Alex T.", location: "DUMBO", text: "Super convenient location and amazing service.", rating: 5 },
  { name: "Maya R.", location: "Park Slope", text: "Finally found my go-to nail spot in BK!", rating: 5 }
];

const nearbyAreas = [
  { name: "Manhattan", slug: "manhattan", distance: "15 min" },
  { name: "Queens", slug: "queens", distance: "20 min" },
  { name: "Staten Island", slug: "staten-island", distance: "30 min" }
];
---

<BaseLayout title={pageTitle} description={pageDescription} pageType="area">
    <section class="area-hero">
      <div class="area-hero-bg">
        <img src={areaData.imageHero} alt="Nail salon in Brooklyn" class="hero-bg-image" />
        <div class="hero-overlay"></div>
      </div>
      <div class="hero-content">
        <div class="hero-badge">🎨 CREATIVE HUB</div>
        <h1 class="hero-title">{areaData.heroTitle}</h1>
        <p class="hero-subtitle">{areaData.heroSubtitle}</p>
        <div class="hero-actions">
          <a href="/booking" class="btn-primary">Book Now →</a>
          <a href="#services" class="btn-secondary">Explore Services</a>
        </div>
      </div>
      <div class="hero-scroll">
        <span>Scroll to explore</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="2"/>
        </svg>
      </div>
    </section>

    <section class="area-stats">
      <div class="stats-container">
        {areaData.stats.map(stat => (
          <div class="stat-card">
            <div class="stat-value">{stat.value}</div>
            <div class="stat-label">{stat.label}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="area-description">
      <div class="desc-container">
        <div class="desc-content">
          <h2>Nail Artistry in <span class="highlight">Brooklyn</span></h2>
          <p>{areaData.description}</p>
          <div class="features-grid">
            {areaData.features.map(feature => (
              <div class="feature-item">
                <i class={`fas ${feature.icon}`}></i>
                <div>
                  <h4>{feature.title}</h4>
                  <p>{feature.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="desc-image">
          <img src="/images/brooklyn-salon.png" alt="Modern nail salon interior in Brooklyn" />
          <div class="floating-badge">
            <span>✨ Walk-ins welcome</span>
          </div>
        </div>
      </div>
    </section>

    <section class="area-services" id="services">
      <div class="services-header">
        <span class="section-badge">OUR SERVICES</span>
        <h2>Nail Services in <span class="highlight">Brooklyn</span></h2>
        <p>Professional nail care tailored to your style in the heart of BK</p>
      </div>
      <div class="services-grid">
        {servicesInArea.map(service => (
          <div class="service-card">
            {service.popular && <span class="popular-badge">🔥 Most Popular</span>}
            <h3>{service.name}</h3>
            <div class="service-meta">
              <span class="price">{service.price}</span>
              <span class="duration">⏱ {service.duration}</span>
            </div>
            <a href={`/services/${service.slug}`} class="service-link">Learn More →</a>
          </div>
        ))}
      </div>
      <div class="services-cta">
        <a href="/booking" class="btn-large">Book Your Appointment →</a>
      </div>
    </section>

    <section class="area-map">
      <div class="map-container">
        <div class="map-info">
          <div class="info-icon">📍</div>
          <h2>Visit Us in <span class="highlight">Brooklyn</span></h2>
          <p>245 Bedford Avenue, Brooklyn, NY 11211</p>
          <div class="info-details">
            <div class="detail">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" stroke="currentColor"/>
                <polyline points="12 6 12 12 16 14" stroke="currentColor"/>
              </svg>
              <span>Mon-Fri: 9am-9pm | Sat: 10am-8pm | Sun: 10am-6pm</span>
            </div>
            <div class="detail">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor"/>
              </svg>
              <span>+1 (718) 555-1234</span>
            </div>
          </div>
          <a href={areaData.mapEmbed} target="_blank" class="map-link">Get Directions →</a>
        </div>
        <div class="map-embed">
          <iframe src={areaData.mapEmbed} width="100%" height="400" style="border:0; border-radius: 32px;" allowfullscreen="" loading="lazy" title="NY Nails Brooklyn Location"></iframe>
        </div>
      </div>
    </section>

    <section class="area-testimonials">
      <div class="testimonials-header">
        <span class="section-badge">CLIENT LOVE</span>
        <h2>What Brooklyn Says <span class="highlight">About Us</span></h2>
      </div>
      <div class="testimonials-grid">
        {areaTestimonials.map(testimonial => (
          <div class="testimonial-card">
            <div class="stars">
              {[...Array(5)].map((_, i) => <span class={i < testimonial.rating ? "star filled" : "star"}>★</span>)}
            </div>
            <p>"{testimonial.text}"</p>
            <div class="client"><strong>{testimonial.name}</strong><span>{testimonial.location}</span></div>
          </div>
        ))}
      </div>
    </section>

    <section class="nearby-areas">
      <div class="nearby-header"><h2>Also Serving Nearby <span class="highlight">Areas</span></h2><p>Visit our locations across New York City</p></div>
      <div class="nearby-grid">
        {nearbyAreas.map(area => (<a href={`/areas/${area.slug}`} class="nearby-card"><span class="area-name">{area.name}</span><span class="area-distance">{area.distance}</span><span class="area-arrow">→</span></a>))}
      </div>
    </section>

    <section class="area-cta">
      <div class="cta-content"><div class="cta-icon">💅</div><h2>Ready for Your Dream Nails in Brooklyn?</h2><p>Book your appointment online or walk in today — we can't wait to meet you!</p><div class="cta-buttons"><a href="/booking" class="btn-primary">Book Now</a><a href="/contact" class="btn-secondary">Contact Us</a></div></div>
    </section>
</BaseLayout>

<style>
  /* Все стили такие же как в manhattan.astro */
  .area-hero { position: relative; min-height: 80vh; display: flex; align-items: center; justify-content: center; text-align: center; overflow: hidden; }
  .area-hero-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; }
  .hero-bg-image { width: 100%; height: 100%; object-fit: cover; }
  .hero-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.4) 100%); }
  .hero-content { position: relative; z-index: 2; color: white; padding: 2rem; }
  .hero-badge { display: inline-block; padding: 6px 16px; background: rgba(255,255,255,0.2); backdrop-filter: blur(10px); border-radius: 100px; font-size: 14px; margin-bottom: 20px; }
  .hero-title { font-family: 'Caveat Brush', cursive; font-size: 120px; margin: 0 0 20px; line-height: 1; }
  .hero-subtitle { font-size: 24px; margin-bottom: 32px; opacity: 0.9; }
  .hero-actions { display: flex; gap: 20px; justify-content: center; }
  .btn-primary, .btn-secondary { padding: 14px 32px; border-radius: 100px; text-decoration: none; font-weight: 600; transition: all 0.3s ease; }
  .btn-primary { background: #FF0000; color: white; }
  .btn-primary:hover { background: #cc0000; transform: translateY(-3px); }
  .btn-secondary { background: transparent; color: white; border: 2px solid white; }
  .btn-secondary:hover { background: white; color: #FF0000; transform: translateY(-3px); }
  .hero-scroll { position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 8px; font-size: 12px; color: #fff; animation: bounce 2s infinite; }
  @keyframes bounce { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(-10px)} }
  .area-stats { padding: 60px 0; background: #f8f8f8; }
  .stats-container { max-width: 1520px; margin: 0 auto; padding: 0 26px; display: grid; grid-template-columns: repeat(4,1fr); gap: 30px; text-align: center; }
  .stat-value { font-family: 'Sonsie One', cursive; font-size: 48px; color: #FF0000; }
  .stat-label { font-family: 'Inter', sans-serif; font-size: 14px; color: #666; }
  .area-description { padding: 80px 0; background: white; }
  .desc-container { max-width: 1520px; margin: 0 auto; padding: 0 26px; display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; }
  .desc-content h2 { font-family: 'Caveat Brush', cursive; font-size: 48px; margin-bottom: 24px; }
  .desc-content p { font-family: 'Inter', sans-serif; font-size: 16px; line-height: 1.6; color: #555; margin-bottom: 32px; }
  .features-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 24px; }
  .feature-item { display: flex; gap: 16px; align-items: flex-start; }
  .feature-item i { font-size: 24px; color: #FF0000; }
  .feature-item h4 { font-family: 'Inter', sans-serif; font-weight: 600; margin: 0 0 4px; }
  .feature-item p { font-size: 13px; margin: 0; }
  .desc-image { position: relative; }
  .desc-image img { width: 100%; border-radius: 32px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
  .floating-badge { position: absolute; bottom: -20px; right: -20px; background: #FF0000; color: white; padding: 12px 24px; border-radius: 100px; font-weight: 600; box-shadow: 0 10px 20px rgba(255,0,0,0.2); }
  .area-services { padding: 80px 0; background: linear-gradient(135deg, #FF0000 0%, #cc0000 100%); color: white; }
  .services-header { text-align: center; margin-bottom: 50px; }
  .section-badge { display: inline-block; padding: 4px 12px; background: rgba(255,255,255,0.2); border-radius: 100px; font-size: 12px; margin-bottom: 16px; }
  .services-header h2 { font-family: 'Caveat Brush', cursive; font-size: 48px; margin-bottom: 16px; }
  .services-header p { font-size: 16px; opacity: 0.9; }
  .services-grid { max-width: 1520px; margin: 0 auto; padding: 0 26px; display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
  .service-card { background: white; border-radius: 24px; padding: 28px; color: #1E1E1E; position: relative; transition: transform 0.3s ease; }
  .service-card:hover { transform: translateY(-5px); }
  .popular-badge { position: absolute; top: -12px; right: 20px; background: #FFD700; color: #1E1E1E; padding: 4px 12px; border-radius: 100px; font-size: 12px; font-weight: 600; }
  .service-card h3 { font-family: 'Sonsie One', cursive; font-size: 22px; margin-bottom: 12px; }
  .service-meta { display: flex; gap: 16px; margin-bottom: 20px; }
  .price { font-size: 24px; font-weight: 700; color: #FF0000; }
  .duration { color: #666; }
  .service-link { color: #FF0000; text-decoration: none; font-weight: 600; }
  .services-cta { text-align: center; margin-top: 40px; }
  .btn-large { display: inline-block; background: white; color: #FF0000; padding: 16px 40px; border-radius: 100px; text-decoration: none; font-weight: 600; transition: all 0.3s ease; }
  .btn-large:hover { transform: scale(1.02); }
  .area-map { padding: 80px 0; background: #f8f8f8; }
  .map-container { max-width: 1520px; margin: 0 auto; padding: 0 26px; display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; }
  .info-icon { font-size: 48px; margin-bottom: 16px; }
  .map-info h2 { font-family: 'Caveat Brush', cursive; font-size: 40px; margin-bottom: 16px; }
  .map-info p { font-size: 18px; color: #555; margin-bottom: 24px; }
  .info-details { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
  .detail { display: flex; align-items: center; gap: 12px; color: #555; }
  .map-link { color: #FF0000; text-decoration: none; font-weight: 600; }
  .map-embed iframe { width: 100%; border-radius: 32px; }
  .area-testimonials { padding: 80px 0; background: white; }
  .testimonials-header { text-align: center; margin-bottom: 50px; }
  .testimonials-header h2 { font-family: 'Caveat Brush', cursive; font-size: 48px; }
  .testimonials-grid { max-width: 1520px; margin: 0 auto; padding: 0 26px; display: grid; grid-template-columns: repeat(3,1fr); gap: 30px; }
  .testimonial-card { background: #f8f8f8; padding: 28px; border-radius: 24px; }
  .stars { margin-bottom: 16px; }
  .star { color: #ddd; font-size: 18px; }
  .star.filled { color: #FFD700; }
  .testimonial-card p { font-family: 'Inter', sans-serif; font-size: 15px; line-height: 1.6; color: #555; margin-bottom: 20px; }
  .client { display: flex; flex-direction: column; gap: 4px; }
  .client span { font-size: 13px; color: #999; }
  .nearby-areas { padding: 80px 0; background: linear-gradient(135deg, #f8f8f8 0%, #fff 100%); }
  .nearby-header { text-align: center; margin-bottom: 50px; }
  .nearby-header h2 { font-family: 'Caveat Brush', cursive; font-size: 48px; margin-bottom: 16px; }
  .nearby-grid { max-width: 1520px; margin: 0 auto; padding: 0 26px; display: flex; justify-content: center; gap: 30px; flex-wrap: wrap; }
  .nearby-card { background: white; padding: 24px 32px; border-radius: 24px; text-decoration: none; display: flex; align-items: center; gap: 16px; transition: all 0.3s ease; border: 1px solid #e0e0e0; }
  .nearby-card:hover { transform: translateY(-5px); border-color: #FF0000; }
  .area-name { font-family: 'Sonsie One', cursive; font-size: 20px; color: #1E1E1E; }
  .area-distance { color: #FF0000; font-size: 14px; }
  .area-arrow { color: #FF0000; }
  .area-cta { padding: 80px 0; background: linear-gradient(135deg, #FF0000 0%, #cc0000 100%); color: white; text-align: center; }
  .cta-icon { font-size: 60px; margin-bottom: 20px; }
  .area-cta h2 { font-family: 'Caveat Brush', cursive; font-size: 48px; margin-bottom: 16px; }
  .area-cta p { font-size: 18px; margin-bottom: 32px; }
  .cta-buttons { display: flex; gap: 20px; justify-content: center; }
  .area-cta .btn-primary { background: white; color: #FF0000; }
  .area-cta .btn-secondary { background: transparent; color: white; border: 2px solid white; }
  @media (max-width: 1024px) { .hero-title { font-size: 80px; } .stats-container { grid-template-columns: repeat(2,1fr); } .desc-container { grid-template-columns: 1fr; } .services-grid { grid-template-columns: repeat(2,1fr); } .testimonials-grid { grid-template-columns: repeat(2,1fr); } .map-container { grid-template-columns: 1fr; } }
  @media (max-width: 768px) { .hero-title { font-size: 60px; } .hero-subtitle { font-size: 18px; } .hero-actions { flex-direction: column; align-items: center; } .services-grid { grid-template-columns: 1fr; } .testimonials-grid { grid-template-columns: 1fr; } .features-grid { grid-template-columns: 1fr; } .stats-container { grid-template-columns: 1fr; } .nearby-grid { flex-direction: column; align-items: stretch; } .cta-buttons { flex-direction: column; align-items: center; } }
</style>