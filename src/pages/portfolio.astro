---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Nail Art Portfolio NYC | Our Best Work in Manhattan, Brooklyn & Queens";
const pageDescription = "Explore our portfolio of stunning nail art designs in NYC. From classic manicures to intricate 3D art — see why NY Nails is the city's premier salon.";

// Данные портфолио с разными размерами для masonry-сетки
const portfolioItems = [
  {
    id: 1,
    title: "Chrome Aurora Nails",
    service: "Gel Polish",
    category: "gel",
    description: "Iridescent chrome finish with aurora effect. Perfect for special occasions.",
    image: "/images/chromeauroranails.png",
    tags: ["Gel", "Chrome", "Trending 2026"],
    location: "Manhattan",
    size: "large", // большой размер (2 колонки)
    featured: true
  },
  {
    id: 2,
    title: "3D Floral Sculpture",
    service: "Nail Art Design",
    category: "art",
    description: "Hand-sculpted 3D flowers with pearl accents. Luxury bridal design.",
    image: "/images/3Dfloralsculpture.png",
    tags: ["3D Art", "Bridal", "Floral"],
    location: "Brooklyn",
    size: "small"
  },
  {
    id: 3,
    title: "Velvet Matte Finish",
    service: "Dip Powder",
    category: "dip",
    description: "Soft velvet matte texture in deep burgundy. Fall/winter favorite.",
    image: "/images/dippowder.png",
    tags: ["Matte", "Dip Powder", "Seasonal"],
    location: "Queens",
    size: "medium"
  },
  {
    id: 4,
    title: "Glass Nails",
    service: "Nail Extensions",
    category: "extensions",
    description: "Translucent glass effect with gold foil encapsulation.",
    image: "/images/nailrepair.png",
    tags: ["Glass", "Extensions", "Luxury"],
    location: "Manhattan",
    size: "medium",
    featured: true
  },
  {
    id: 5,
    title: "French Ombre",
    service: "Classic Manicure",
    category: "classic",
    description: "Modern twist on French - pink ombre with white tips.",
    image: "/images/classicmanicure.png",
    tags: ["French", "Ombre", "Classic"],
    location: "Staten Island",
    size: "small"
  },
  {
    id: 6,
    title: "Cat Eye Gel",
    service: "Gel Polish",
    category: "gel",
    description: "Magnetic cat eye effect with deep blue shimmer.",
    image: "/images/cateyegel.png",
    tags: ["Cat Eye", "Magnetic", "Gel"],
    location: "Bronx",
    size: "large"
  },
  {
    id: 7,
    title: "Hand-Painted Art",
    service: "Nail Art Design",
    category: "art",
    description: "Custom hand-painted miniature artwork on each nail.",
    image: "/images/handPaintedArt.png",
    tags: ["Hand-Painted", "Custom", "Artistic"],
    location: "Manhattan",
    size: "medium"
  },
  {
    id: 8,
    title: "Pearl Minimalist",
    service: "Nail Art Design",
    category: "art",
    description: "Clean minimalist design with 3D pearl accents.",
    image: "/images/pearlMinimalist.png",
    tags: ["Minimalist", "Pearls", "Elegant"],
    location: "Brooklyn",
    size: "small"
  },
  {
    id: 9,
    title: "Neon Pop Art",
    service: "Nail Art Design",
    category: "art",
    description: "Vibrant neon colors with pop art influences. Summer statement.",
    image: "/images/neonPopArt.png",
    tags: ["Neon", "Pop Art", "Summer"],
    location: "Queens",
    size: "medium"
  },
  {
    id: 10,
    title: "Bridal Lace",
    service: "Nail Art Design",
    category: "art",
    description: "Delicate hand-painted lace pattern. Perfect for weddings.",
    image: "/images/bridallace.png",
    tags: ["Bridal", "Lace", "Elegant"],
    location: "Manhattan",
    size: "small"
  },
  {
    id: 11,
    title: "Chrome Mirror",
    service: "Gel Polish",
    category: "gel",
    description: "High-shine mirror chrome finish in rose gold.",
    image: "/images/gelpolishgold.png",
    tags: ["Chrome", "Mirror", "Trendy"],
    location: "Brooklyn",
    size: "medium"
  },
  {
    id: 12,
    title: "Winter Wonderland",
    service: "Nail Art Design",
    category: "art",
    description: "Snowflakes and glitter winter-themed design.",
    image: "/images/winterwonderland.png",
    tags: ["Seasonal", "Winter", "Glitter"],
    location: "Queens",
    size: "large"
  }
];

const categories = [
  { id: "all", name: "All Work", icon: "fa-grid-2" },
  { id: "gel", name: "Gel Polish", icon: "fa-droplet" },
  { id: "art", name: "Nail Art", icon: "fa-palette" },
  { id: "extensions", name: "Extensions", icon: "fa-ruler" },
  { id: "classic", name: "Classic", icon: "fa-hand-peace" },
  { id: "dip", name: "Dip Powder", icon: "fa-brush" }
];
---

<BaseLayout title={pageTitle} description={pageDescription} pageType="portfolio">
    <!-- Hero секция -->
    <section class="portfolio-hero">
      <div class="hero-content">
        <div class="hero-badge">📸 OUR WORK</div>
        <h1 class="hero-title">NAIL ART<span class="highlight"> PORTFOLIO</span></h1>
        <p class="hero-subtitle">Explore our collection of stunning nail designs —<br>each piece is uniquely crafted for our clients across New York</p>
      </div>
      <div class="hero-stats">
        <div class="stat"><span class="stat-number">500+</span><span class="stat-label">Happy Clients</span></div>
        <div class="stat"><span class="stat-number">1000+</span><span class="stat-label">Designs Created</span></div>
        <div class="stat"><span class="stat-number">50+</span><span class="stat-label">5-Star Reviews</span></div>
      </div>
    </section>

    <!-- Фильтры -->
    <section class="portfolio-filters">
      <div class="filters-container">
        {categories.map(cat => (
          <button class="filter-btn" data-filter={cat.id}>
            <i class={`fas ${cat.icon}`}></i>
            <span>{cat.name}</span>
          </button>
        ))}
      </div>
    </section>

    <!-- Masonry Gallery -->
    <section class="portfolio-gallery">
      <div class="gallery-container" id="galleryContainer">
        {portfolioItems.map((item, index) => (
          <div 
            class={`gallery-item gallery-item--${item.size} ${item.featured ? 'gallery-item--featured' : ''}`}
            data-category={item.category}
            data-id={item.id}
            style={`--item-index: ${index}`}
          >
            <div class="gallery-card">
              <div class="gallery-image-wrapper">
                <img 
                  src={item.image} 
                  alt={`${item.title} - ${item.service} at our ${item.location} nail salon`}
                  class="gallery-image"
                  loading="lazy"
                />
                <div class="gallery-overlay">
                  <div class="overlay-content">
                    <span class="service-badge">{item.service}</span>
                    <h3 class="overlay-title">{item.title}</h3>
                    <p class="overlay-description">{item.description}</p>
                    <div class="overlay-tags">
                      {item.tags.map(tag => (
                        <span class="overlay-tag">{tag}</span>
                      ))}
                    </div>
                    <div class="overlay-footer">
                      <span class="location-icon">📍 {item.location}</span>
                      <a href={`/services/${item.service.toLowerCase().replace(/ /g, '-')}`} class="service-link">View Service →</a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Load More -->
    <section class="portfolio-loadmore">
      <button id="loadMoreBtn" class="load-more-btn">
        <span>Load More</span>
        <i class="fas fa-arrow-down"></i>
      </button>
    </section>

    <!-- CTA секция -->
    <section class="portfolio-cta">
      <div class="cta-content">
        <div class="cta-icon">💅</div>
        <h2>Ready for Your Own Masterpiece?</h2>
        <p>Book your appointment today and let our artists create something beautiful just for you</p>
        <div class="cta-buttons">
          <a href="/booking" class="btn-primary">Book Now →</a>
          <a href="/contact" class="btn-secondary">Contact Us</a>
        </div>
      </div>
    </section>
</BaseLayout>

<style>
  /* Hero секция */
  .portfolio-hero {
    position: relative;
    padding: 100px 0 60px;
    background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 100%);
    text-align: center;
    overflow: hidden;
  }
  
  .portfolio-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,0,0,0.1) 0%, transparent 70%);
    border-radius: 50%;
  }
  
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    border-radius: 100px;
    font-size: 14px;
    color: #FF0000;
    margin-bottom: 20px;
  }
  
  .hero-title {
    font-family: 'Caveat Brush', cursive;
    font-size: 80px;
    color: white;
    margin-bottom: 20px;
    line-height: 1.1;
  }
  
  .hero-title .highlight {
    color: #FF0000;
  }
  
  .hero-subtitle {
    font-size: 18px;
    color: rgba(255,255,255,0.8);
    line-height: 1.6;
  }
  
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 60px;
    margin-top: 50px;
    position: relative;
    z-index: 2;
  }
  
  .stat {
    text-align: center;
  }
  
  .stat-number {
    display: block;
    font-family: 'Sonsie One', cursive;
    font-size: 36px;
    color: #FF0000;
  }
  
  .stat-label {
    font-size: 14px;
    color: rgba(255,255,255,0.7);
  }
  
  /* Фильтры */
  .portfolio-filters {
    padding: 40px 0;
    background: white;
    position: sticky;
    top: 60px;
    z-index: 100;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }
  
  .filters-container {
    max-width: 1520px;
    margin: 0 auto;
    padding: 0 26px;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  
  .filter-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 24px;
    background: #f5f5f5;
    border: none;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #666;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .filter-btn i {
    font-size: 14px;
  }
  
  .filter-btn:hover {
    background: #FF0000;
    color: white;
    transform: translateY(-2px);
  }
  
  .filter-btn.active {
    background: #FF0000;
    color: white;
  }
  
  /* Masonry Gallery */
  .portfolio-gallery {
    padding: 60px 0;
    background: #f8f8f8;
  }
  
  .gallery-container {
    max-width: 1520px;
    margin: 0 auto;
    padding: 0 26px;
    column-count: 4;
    column-gap: 24px;
  }
  
  .gallery-item {
    break-inside: avoid;
    margin-bottom: 24px;
    animation: fadeInUp 0.6s ease forwards;
    animation-delay: calc(var(--item-index) * 0.03s);
    opacity: 0;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .gallery-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .gallery-card:hover {
    transform: translateY(-5px);
  }
  
  .gallery-image-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  
  .gallery-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }
  
  .gallery-card:hover .gallery-image {
    transform: scale(1.05);
  }
  
  /* Overlay эффект */
  .gallery-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.85) 100%);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s ease;
  }
  
  .gallery-card:hover .gallery-overlay {
    opacity: 1;
    visibility: visible;
  }
  
  .overlay-content {
    text-align: center;
    padding: 24px;
    transform: translateY(20px);
    transition: transform 0.4s ease;
  }
  
  .gallery-card:hover .overlay-content {
    transform: translateY(0);
  }
  
  .service-badge {
    display: inline-block;
    padding: 4px 12px;
    background: #FF0000;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: white;
    margin-bottom: 12px;
  }
  
  .overlay-title {
    font-family: 'Sonsie One', cursive;
    font-size: 18px;
    color: white;
    margin: 0 0 10px;
    line-height: 1.3;
  }
  
  .overlay-description {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    line-height: 1.5;
    color: rgba(255,255,255,0.7);
    margin: 0 0 16px;
  }
  
  .overlay-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-bottom: 16px;
  }
  
  .overlay-tag {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    padding: 3px 10px;
    background: rgba(255,255,255,0.1);
    border-radius: 100px;
    color: rgba(255,255,255,0.8);
  }
  
  .overlay-footer {
    display: flex;
    justify-content: center;
    gap: 16px;
    padding-top: 12px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  
  .location-icon {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: rgba(255,255,255,0.6);
  }
  
  .service-link {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: #FF0000;
    text-decoration: none;
    font-weight: 600;
  }
  
  /* Скрытие при фильтрации */
  .gallery-item.hide {
    display: none;
  }
  
  /* Load More */
  .portfolio-loadmore {
    padding: 40px 0 80px;
    text-align: center;
    background: #f8f8f8;
  }
  
  .load-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 32px;
    background: white;
    border: 2px solid #FF0000;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #FF0000;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .load-more-btn:hover {
    background: #FF0000;
    color: white;
    gap: 16px;
  }
  
  /* CTA */
  .portfolio-cta {
    padding: 80px 0;
    background: linear-gradient(135deg, #FF0000 0%, #cc0000 100%);
    color: white;
    text-align: center;
  }
  
  .cta-icon {
    font-size: 60px;
    margin-bottom: 20px;
  }
  
  .portfolio-cta h2 {
    font-family: 'Caveat Brush', cursive;
    font-size: 48px;
    margin-bottom: 16px;
  }
  
  .portfolio-cta p {
    font-size: 18px;
    margin-bottom: 32px;
    opacity: 0.9;
  }
  
  .cta-buttons {
    display: flex;
    gap: 20px;
    justify-content: center;
  }
  
  .portfolio-cta .btn-primary {
    background: white;
    color: #FF0000;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }
  
  .portfolio-cta .btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }
  
  .portfolio-cta .btn-secondary {
    background: transparent;
    color: white;
    border: 2px solid white;
    padding: 14px 32px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }
  
  .portfolio-cta .btn-secondary:hover {
    background: white;
    color: #FF0000;
    transform: translateY(-3px);
  }
  
  /* ========== АДАПТИВНОСТЬ ========== */
  
  @media (max-width: 1200px) {
    .gallery-container {
      column-count: 3;
    }
  }
  
  @media (max-width: 768px) {
    .hero-title {
      font-size: 48px;
    }
    
    .hero-subtitle {
      font-size: 16px;
    }
    
    .hero-stats {
      flex-direction: column;
      gap: 20px;
    }
    
    .filters-container {
      gap: 8px;
    }
    
    .filter-btn {
      padding: 6px 16px;
      font-size: 12px;
    }
    
    .gallery-container {
      column-count: 2;
      padding: 0 16px;
    }
    
    .portfolio-cta h2 {
      font-size: 32px;
    }
    
    .portfolio-cta p {
      font-size: 14px;
      padding: 0 20px;
    }
    
    .cta-buttons {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
  }
  
  @media (max-width: 480px) {
    .hero-title {
      font-size: 36px;
    }
    
    .gallery-container {
      column-count: 1;
    }
    
    .portfolio-filters {
      position: relative;
      top: 0;
    }
    
    .filter-btn span {
      display: none;
    }
    
    .filter-btn i {
      font-size: 18px;
      margin: 0;
    }
    
    .filter-btn {
      padding: 12px;
    }
    
    .overlay-title {
      font-size: 16px;
    }
    
    .overlay-description {
      font-size: 11px;
    }
  }
</style>

<script>
  // Фильтрация портфолио
  const filterButtons = document.querySelectorAll('.filter-btn');
  const galleryItems = document.querySelectorAll('.gallery-item');
  let activeFilter = 'all';
  
  // Функция фильтрации
  function filterGallery(filterValue) {
    galleryItems.forEach(item => {
      const itemCategory = item.getAttribute('data-category');
      
      if (filterValue === 'all' || itemCategory === filterValue) {
        item.classList.remove('hide');
        // Добавляем плавное появление
        item.style.opacity = '0';
        setTimeout(() => {
          item.style.opacity = '1';
        }, 10);
      } else {
        item.classList.add('hide');
      }
    });
  }
  
  // Добавляем обработчики на кнопки фильтров
  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      // Убираем active у всех кнопок
      filterButtons.forEach(btn => btn.classList.remove('active'));
      // Добавляем active текущей
      button.classList.add('active');
      
      // Получаем значение фильтра
      activeFilter = button.getAttribute('data-filter');
      
      // Применяем фильтрацию
      filterGallery(activeFilter);
    });
  });
  
  // Load More функционал
  const loadMoreBtn = document.getElementById('loadMoreBtn');
  let visibleItems = 9;
  const items = Array.from(document.querySelectorAll('.gallery-item:not(.hide)'));
  const totalItems = document.querySelectorAll('.gallery-item').length;
  
  function updateVisibleItems() {
    const visibleItemsList = Array.from(document.querySelectorAll('.gallery-item:not(.hide)'));
    const totalVisible = visibleItemsList.length;
    
    visibleItemsList.forEach((item, index) => {
      if (index < visibleItems) {
        item.style.display = 'block';
      } else {
        item.style.display = 'none';
      }
    });
    
    if (visibleItems >= totalVisible && loadMoreBtn) {
      loadMoreBtn.style.display = 'none';
    } else if (loadMoreBtn) {
      loadMoreBtn.style.display = 'inline-flex';
    }
  }
  
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', () => {
      visibleItems += 6;
      updateVisibleItems();
    });
  }
  
  // Инициализация
  function init() {
    // Показываем первые 9 элементов
    visibleItems = 9;
    updateVisibleItems();
    
    // Добавляем CSS для скрытых элементов
    const style = document.createElement('style');
    style.textContent = `
      .gallery-item.hide {
        display: none !important;
      }
      .gallery-item {
        transition: opacity 0.3s ease;
      }
    `;
    document.head.appendChild(style);
  }
  
  init();
</script>